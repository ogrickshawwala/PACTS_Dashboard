# PACTS Dashboard environment configuration.
# Copy to .env and adjust per deployment stage. The API base URL is the ONLY
# environment-specific value; it must never be hardcoded in source.
#
# Local:  http://127.0.0.1:1800
# LAN:    http://192.168.x.x:1800
# AWS:    https://api.company.com
VITE_PACTS_API_URL=http://127.0.0.1:1800
